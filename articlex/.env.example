# ============================================================
# ArticleX — Environment Variables
# ============================================================
# Copy this file to .env and fill in the values you need.
# All variables are OPTIONAL — the app works without any of them.
#
# Variables prefixed with VITE_ are exposed to the browser.
# Variables WITHOUT the VITE_ prefix are server-only (Vercel API routes).
# ============================================================

# ─── Deployment ──────────────────────────────────────────────
# Base path for the app (set automatically by each platform)
#   Vercel  → leave empty or "/"
#   GitHub Pages → "/ArticleX/" (matches repo name)
VITE_BASE_PATH=/

# Optional shared API base URL for backend endpoints
# For Vercel: leave empty (API routes are at /api/* on the same domain)
# For external API: https://api.example.com
VITE_API_BASE_URL=

# ─── Razorpay (payments) ────────────────────────────────────
# Frontend: public key shown to the browser
VITE_RAZORPAY_KEY_ID=
# Frontend: endpoint to verify payments (Vercel default: /api/payments/verify)
VITE_RAZORPAY_VERIFY_ENDPOINT=/api/payments/verify

# Backend (server-only): secret key for signature verification
# Add this in Vercel Dashboard → Settings → Environment Variables
RAZORPAY_KEY_SECRET=

# ─── Stripe (payments) ──────────────────────────────────────
# Frontend: publishable key shown to the browser
VITE_STRIPE_PUBLISHABLE_KEY=
# Frontend: endpoint to verify payments (Vercel default: /api/payments/verify)
VITE_STRIPE_VERIFY_ENDPOINT=/api/payments/verify

# Backend (server-only): secret key for Stripe API calls
# Add this in Vercel Dashboard → Settings → Environment Variables
STRIPE_SECRET_KEY=

# ─── Clerk (auth) ───────────────────────────────────────────
# Frontend: publishable key
VITE_CLERK_PUBLISHABLE_KEY=

# Backend (server-only): secret key for Clerk API
CLERK_SECRET_KEY=

# ─── Supabase (backend / auth / database) ───────────────────
# Frontend: project URL and anon key (safe for browser)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Backend (server-only): service role key (full database access)
SUPABASE_SERVICE_ROLE_KEY=

# ─── Firebase (backend / auth / database) ────────────────────
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
