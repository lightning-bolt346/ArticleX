# Frontend base path (use "/" for normal Vercel deployments)
VITE_BASE_PATH=/

# Optional shared API base for backend endpoints (Supabase edge function, Firebase function, custom API)
# Example: https://api.example.com
VITE_API_BASE_URL=

# Razorpay (optional)
VITE_RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxx
# Optional backend endpoint to verify successful Razorpay payments
# Example: /api/payments/razorpay/verify
VITE_RAZORPAY_VERIFY_ENDPOINT=

# Stripe (optional)
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_xxxxxxxxxxxx
# Optional backend endpoint to verify Stripe sessions/payments
# Example: /api/payments/stripe/verify
VITE_STRIPE_VERIFY_ENDPOINT=

# Clerk (optional auth)
VITE_CLERK_PUBLISHABLE_KEY=pk_live_xxxxxxxxxxxx

# Supabase (optional backend/auth/database)
VITE_SUPABASE_URL=https://xxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...your-anon-key

# Firebase (optional backend/auth/database)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
